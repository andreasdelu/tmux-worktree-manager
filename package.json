{
  "name": "tmux-worktree-manager",
  "version": "1.0.2",
  "private": true,
  "description": "A tmux-first Git worktree launcher and session bootstrapper.",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build --target bun src/index.tsx --outfile dist/twm.js",
    "compile": "bun build --target bun --compile --format=esm --minify --sourcemap --bytecode src/index.tsx --outfile dist/twm",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "dependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "ink": "^7.0.1",
    "react": "^19.2.0",
    "react-devtools-core": "^7.0.1"
  }
}
